# What this file is for:
# Keep the repo to just what someone needs to clone and run Focus Buddy locally
# (backend/, frontend/, requirements.txt, README, tests, extension, deploy config,
# and the project-memory docs). Everything below is a secret, generated locally,
# or agent/dev-only tooling that the app does not need to run.

# Secrets - never commit API keys or local deployment credentials
.env
.env.local
.env.*.local
*.pem
*.key

# Database - generated on first run, not source code
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Python - virtualenvs, bytecode, build output, test caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.venv.broken-*/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# JavaScript / frontend tooling (we use CDNs + no build step, so none of this ships)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.next/
.nuxt/
.svelte-kit/
coverage/

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Generated / context-heavy artifacts - not needed to run the app
promptlab/
v0-export/
.playwright-mcp/
playwright-*.png
playwright-report/
test-results/
skills-lock.json

# Agent / dev-only tooling - not needed to run the app.
tools/
.claude/
.agents/
.codex/

# Agent project-memory + dev-only files - hidden from the public repo because the app
# does not need them to run. Deploy config (pyproject.toml, vercel.json, vercel_build.py)
# is intentionally NOT ignored so the hosted Vercel demo keeps working.
CLAUDE.md
AGENTS.md
.gitattributes
tests/
extension/README.md

# docs/ holds agent handoff notes - not needed to run the app.
docs/

# Hosting CLI local state
.vercel/
.render/
/public/

# Local logs / runtime output
*.log
logs/
tmp/
temp/
